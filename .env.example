# Copy this file to .env.local and fill in real values for local development.
# .env.local is gitignored; never commit real secrets.
# In Vercel, set these in the project's Environment Variables dashboard instead.

# --- Database (Neon Postgres in production, local Postgres in dev) ---
# In production: connection string from the Neon dashboard (pooled connection).
#   The src/db/index.ts driver swap auto-detects Neon URLs (containing "neon.tech")
#   and uses the @neondatabase/serverless HTTP driver. Other URLs use postgres.js.
# In local dev: point at the docker-compose Postgres (run `npm run db:up`).
#   Local: postgres://postgres:postgres@localhost:5432/brokerage_dev
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# --- Auth (Better Auth, self-hosted) ---
# BETTER_AUTH_SECRET signs session tokens. Min 32 chars. Generate with:
#   openssl rand -base64 48
# Rotate periodically. Changing it invalidates all existing sessions.
BETTER_AUTH_SECRET=replace-me-with-a-long-random-string-of-at-least-32-chars
# Public origin of the deployed app. Used for OAuth redirects + cookie domain.
BETTER_AUTH_URL=http://localhost:3000

# --- Email (Resend) ---
# From Resend dashboard → API keys.
RESEND_API_KEY=re_...

# --- In-app feedback widget ---
# Set to "false" in production once handoff is complete (Lakebridge launch).
# Controls whether the floating feedback button + section zones render at all.
NEXT_PUBLIC_FEEDBACK_ENABLED=true

# Build-time commit SHA. Auto-set by next.config.ts from VERCEL_GIT_COMMIT_SHA
# (in Vercel) or `git rev-parse HEAD` (locally). Don't set manually.
# NEXT_PUBLIC_COMMIT_SHA=auto
